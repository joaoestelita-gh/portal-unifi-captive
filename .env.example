# ==========================================================================
# Portal Cativo - Variaveis de Ambiente (exemplo)
# Copie este arquivo para .env.local e preencha com os valores reais.
# Nao versione o .env.local com segredos reais.
# ==========================================================================

# --------------------------------------------------------------------------
# Banco de dados (Neon / PostgreSQL) - OBRIGATORIO
# String de conexao do Postgres. No Neon, copie a "Connection string".
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --------------------------------------------------------------------------
# Autenticacao (Better Auth) - OBRIGATORIO
# Segredo usado para assinar sessoes e hashear a senha do admin.
# Gere um valor seguro com: openssl rand -base64 32
# --------------------------------------------------------------------------
BETTER_AUTH_SECRET="troque-por-um-segredo-aleatorio-de-32-bytes"

# --------------------------------------------------------------------------
# Usuario administrador inicial (usado pelo script scripts/create-admin.ts)
# Opcional: se nao definido, usa os valores padrao indicados abaixo.
# --------------------------------------------------------------------------
ADMIN_EMAIL="admin@portal.local"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Administrador"

# --------------------------------------------------------------------------
# Integracao com UniFi Controller / CloudGateway
# Opcional: necessario apenas se usar APs UniFi.
# A URL deve ser acessivel a partir do servidor do portal (ex: Cloudflare Tunnel).
# --------------------------------------------------------------------------
UNIFI_CONTROLLER_URL="https://192.168.1.1"
UNIFI_USERNAME="admin"
UNIFI_PASSWORD=""
UNIFI_SITE="default"

# --------------------------------------------------------------------------
# Integracao RADIUS (Aruba Instant On via FreeRADIUS)
# Opcional: necessario apenas se usar APs Aruba.
# Segredo compartilhado entre o FreeRADIUS (rlm_rest) e o endpoint
# /api/radius/authorize deste portal. Deve coincidir nos dois lados.
# --------------------------------------------------------------------------
RADIUS_REST_SECRET="troque-por-um-segredo-compartilhado"

# --------------------------------------------------------------------------
# Cron de limpeza de sessoes (/api/cron/sessions)
# Opcional: protege o endpoint de cron. Use o mesmo valor no agendador
# (ex: Vercel Cron) no header Authorization: Bearer <CRON_SECRET>.
# --------------------------------------------------------------------------
CRON_SECRET="troque-por-um-segredo-de-cron"
